  m_Script: {fileID: 11500000, guid: 065a3ea6656a6d7449f5f97f395527cb, type: 3}
  m_Name: Diary2
  m_EditorClassIdentifier: 
  backgroundFile: {fileID: 0}
  titleFile: Giorno 27
  textFile: 'Oggi abbiamo ricevuto meno razioni del solito.

    Dicono che i rifornimenti
    stanno finendo.

    Nessuno si lamenta, ma si vede negli occhi.

    La guerra
    va avanti, ma qui sembra tutto fermo.

    Come se stessimo aspettando qualcosa.'
